# ===== 基础配置 =====
SECRET_KEY=replace_with_a_random_secret
ADMIN_REGISTER_PASSWORD=your_admin_create_password

# ===== Stripe（必配，Stripe-only） =====
# 必须是 sk_ 开头的服务端密钥
STRIPE_SECRET_KEY=sk_test_replace_me

# Stripe 提现币种（如 usd、cny、eur），需与 Stripe 后台已绑定的外部账户币种一致
# STRIPE_PAYOUT_CURRENCY=usd

# ===== 数据库配置 =====
# 默认留空使用本地 SQLite（data.db）
# 需要连接 PostgreSQL 时填写完整 URL
DATABASE_URL=

# 是否允许从 .env 自动加载 DATABASE_URL
# 默认 false；仅在你确认要用 .env 中的远端库时设为 true
ALLOW_DOTENV_DATABASE_URL=false

# 是否在 import app 时执行初始化/迁移/种子
# 默认 false；仅在确有需要时设为 true
APP_BOOTSTRAP_ON_IMPORT=false

# ===== 邮件（找回密码功能）可选 =====
MAIL_SERVER=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=
MAIL_USE_TLS=true
PASSWORD_RESET_CODE_TTL_MINUTES=10
